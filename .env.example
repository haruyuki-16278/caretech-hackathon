# サーバー設定サンプル(実際の値は環境変数として設定し、リポジトリにはコミットしないこと)

# --- Azure OpenAI (対話LLM。未設定の場合はルールベースの簡易応答にフォールバックします) ---
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# --- Azure Speech (音声認識/音声合成。未設定の場合は音声機能がフォールバック動作になります) ---
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
AZURE_SPEECH_STT_LANGUAGE=ja-JP
AZURE_SPEECH_TTS_VOICE=ja-JP-NanamiNeural

# --- 相談窓口データ (未設定時は data/consultation_offices.json を自動探索します) ---
CONSULTATION_OFFICES_PATH=

# --- 音声チャットAPI (/api/voice-chat) のアップロードサイズ上限。未設定時は10MB ---
VOICE_MAX_UPLOAD_BYTES=
