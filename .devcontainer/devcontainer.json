{
  "name": "caretech-hackathon",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",
  "postCreateCommand": "pip install -r backend/requirements-dev.txt",
  "forwardPorts": [8000],
  "portsAttributes": {
    "8000": {
      "label": "app",
      "visibility": "public"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": ["ms-python.python"]
    }
  }
}
